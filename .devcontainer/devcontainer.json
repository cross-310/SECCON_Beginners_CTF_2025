{
  "name": "SECCON Beginners CTF 2025 Workshop Host",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "version": "latest"
    }
  },
  "hostRequirements": { "cpus": 2 },
  "portsAttributes": {
    "33333": { "label": "misc-kingyo_sukui" },
    "33455": { "label": "web-skipping" },
    "9999":  { "label": "web-log_viewer" }
  },
  "postCreateCommand": "bash workshop/setup.sh",
  "remoteUser": "vscode"
}
